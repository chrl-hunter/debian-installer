#!/bin/bash

# Script de instalación de aplicaciones para Debian
# Uso: sudo bash install_apps.sh

set -e

# Colores
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log()  { echo -e "${GREEN}[OK]${NC} $1"; }
warn() { echo -e "${YELLOW}[INFO]${NC} $1"; }
err()  { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }
title(){ echo -e "\n${CYAN}${BOLD}── $1 ──${NC}"; }

# ─────────────────────────────────────────
# COMPROBAR ROOT
# ─────────────────────────────────────────
[ "$EUID" -ne 0 ] && err "Ejecuta el script como root: sudo bash $0"

# ─────────────────────────────────────────
# SELECTOR INTERACTIVO
# ─────────────────────────────────────────
SECTIONS=(
  "0" "Revisión de repositorios APT"
  "1" "Utilidades (7zip, git, curl, htop...)"
  "2" "Aplicaciones (Chromium, LibreOffice, VLC...)"
  "3" "Visual (Evince, Okular, Flameshot, Kate...)"
  "4" "Fuentes (Liberation, DejaVu, Noto, Nerd Fonts)"
  "5" "Flatpak + Pinta"
)

echo -e "\n${BOLD}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║   Instalador de apps - Debian             ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════╝${NC}"
echo -e "\nSelecciona las secciones a instalar (separadas por espacios)."
echo -e "Escribe ${CYAN}all${NC} para instalarlas todas.\n"

for ((i=0; i<${#SECTIONS[@]}; i+=2)); do
  echo -e "  ${CYAN}[${SECTIONS[$i]}]${NC} ${SECTIONS[$i+1]}"
done

echo ""
read -rp "Tu selección: " SELECTION

# Convertir "all" a todos los índices
if [[ "$SELECTION" == "all" ]]; then
  SELECTION="0 1 2 3 4 5"
fi

# Validar entrada
for s in $SELECTION; do
  [[ "$s" =~ ^[0-5]$ ]] || err "Opción inválida: '$s'. Usa números del 0 al 5 o 'all'."
done

echo ""
warn "Se instalarán las secciones: ${SELECTION}"
read -rp "¿Continuar? [s/N]: " CONFIRM
[[ "$CONFIRM" =~ ^[sS]$ ]] || { echo "Cancelado."; exit 0; }

# ─────────────────────────────────────────
# SECCIÓN 0 — REPOSITORIOS APT
# ─────────────────────────────────────────
section_0() {
  title "Sección 0: Revisión de repositorios APT"
  DEBIAN_VERSION=$(lsb_release -cs 2>/dev/null || cat /etc/debian_version | cut -d. -f1)
  SOURCES_FILE="/etc/apt/sources.list"

  check_and_add_repo() {
    local component="$1"
    if ! grep -qE "^\s*deb .* $DEBIAN_VERSION $component" "$SOURCES_FILE" /etc/apt/sources.list.d/*.list 2>/dev/null; then
      warn "Repositorio '$component' no encontrado. Añadiendo..."
      echo "deb http://deb.debian.org/debian $DEBIAN_VERSION $component" >> "$SOURCES_FILE"
      log "Repositorio '$component' añadido."
    else
      log "Repositorio '$component' ya está configurado."
    fi
  }

  check_and_add_repo "main"
  check_and_add_repo "contrib"
  check_and_add_repo "non-free"
  check_and_add_repo "non-free-firmware"

  warn "Actualizando repositorios..."
  apt update && apt upgrade -y
  log "Repositorios listos."
}

# ─────────────────────────────────────────
# SECCIÓN 1 — UTILIDADES
# ─────────────────────────────────────────
section_1() {
  title "Sección 1: Utilidades"
  apt install -y \
    7zip \
    unrar \
    zip \
    curl \
    wget \
    git \
    gstreamer1.0-libav \
    deja-dup \
    htop \
    fastfetch \
    system-config-printer \
    simple-scan
  log "Utilidades instaladas."
}

# ─────────────────────────────────────────
# SECCIÓN 2 — APLICACIONES
# ─────────────────────────────────────────
section_2() {
  title "Sección 2: Aplicaciones"
  apt install -y \
    chromium \
    libreoffice \
    vlc \
    gimp \
    transmission
  log "Aplicaciones instaladas."
}

# ─────────────────────────────────────────
# SECCIÓN 3 — VISUAL
# ─────────────────────────────────────────
section_3() {
  title "Sección 3: Herramientas visuales"
  apt install -y \
    evince \
    okular \
    pdf-arranger \
    flameshot \
    kate
  log "Herramientas visuales instaladas."
}

# ─────────────────────────────────────────
# SECCIÓN 4 — FUENTES
# ─────────────────────────────────────────
section_4() {
  title "Sección 4: Fuentes"
  apt install -y \
    fonts-liberation \
    fonts-dejavu \
    fonts-noto
  log "Fuentes base instaladas."

  warn "Instalando Nerd Fonts..."
  NERD_FONTS_VERSION=$(curl -s https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest \
    | grep '"tag_name"' | cut -d'"' -f4)
  NERD_FONTS_DIR="/usr/local/share/fonts/nerd-fonts"
  mkdir -p "$NERD_FONTS_DIR"

  install_nerd_font() {
    local font="$1"
    warn "Descargando $font..."
    curl -fLo "/tmp/${font}.zip" \
      "https://github.com/ryanoasis/nerd-fonts/releases/download/${NERD_FONTS_VERSION}/${font}.zip"
    unzip -o "/tmp/${font}.zip" -d "$NERD_FONTS_DIR/$font" '*.ttf' '*.otf' 2>/dev/null
    rm "/tmp/${font}.zip"
    log "$font instalada."
  }

  install_nerd_font "FiraCode"
  install_nerd_font "JetBrainsMono"
  install_nerd_font "Hack"
  install_nerd_font "SourceCodePro"

  fc-cache -fv > /dev/null 2>&1
  log "Nerd Fonts instaladas y caché actualizada."
}

# ─────────────────────────────────────────
# SECCIÓN 5 — FLATPAK + PINTA
# ─────────────────────────────────────────
section_5() {
  title "Sección 5: Flatpak + Pinta"
  apt install -y flatpak
  flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
  flatpak install -y flathub com.github.PintaProject.Pinta
  log "Flatpak y Pinta instalados."
}

# ─────────────────────────────────────────
# EJECUTAR SECCIONES SELECCIONADAS
# ─────────────────────────────────────────
for s in $SELECTION; do
  case $s in
    0) section_0 ;;
    1) section_1 ;;
    2) section_2 ;;
    3) section_3 ;;
    4) section_4 ;;
    5) section_5 ;;
  esac
done

# ─────────────────────────────────────────
# LIMPIEZA
# ─────────────────────────────────────────
warn "Limpiando paquetes innecesarios..."
apt autoremove -y && apt clean

echo ""
echo -e "${GREEN}${BOLD}✔ Instalación completada con éxito.${NC}"
echo -e "${YELLOW}⚠ Reinicia la sesión (o el sistema) para aplicar todos los cambios.${NC}"
